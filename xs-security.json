{
  "xsappname": "simple-cap-app",
  "tenant-mode": "dedicated",
  "oauth2-configuration": {
    "redirect-uris": [
      "https://*.hana.ondemand.com/**"
    ]
  },
  "scopes": [
    {
      "name": "$XSAPPNAME.user",
      "description": "User scope"
    }
  ],
  "role-templates": [
    {
      "name": "User",
      "description": "User role",
      "scope-references": [
        "$XSAPPNAME.user"
      ]
    }
  ]
}